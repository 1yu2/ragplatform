LAYOUT_API_URL=http://192.168.10.60:8888/layout-parsing
LAYOUT_API_TOKEN=
LAYOUT_API_FALLBACK_URL=
LAYOUT_API_FILE_TYPE=0
LAYOUT_API_MAX_NUM_IMGS=512
LAYOUT_API_TIMEOUT_SEC=1200

EMBEDDING_API_URL=http://192.168.10.60:5001/bge_embed
EMBEDDING_MODEL_NAME=bge-m3
EMBEDDING_API_KEY=
EMBEDDING_API_AUTH_HEADER=Authorization
