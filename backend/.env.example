MILVUS_COLLECTION=rag_chunks
MILVUS_COLLECTIONS=rag_chunks
MILVUS_ENABLE_SPARSE=true
MILVUS_CHUNK_TEXT_MAX_LENGTH=16384

MINIO_ENDPOINT=192.168.10.60:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-sth
MINIO_SECURE=false
MINIO_USE_PRESIGNED_URL=true
